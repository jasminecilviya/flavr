{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/proxy" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "overrides": {
    "api/proxy.js": {
      "runtime": "@vercel/node@3"
    }
  }
}
